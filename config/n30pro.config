# Target: Netcore N30 Pro (MT7981B, 512 MB RAM, 128 MB SPI-NAND)
CONFIG_TARGET_mediatek=y
CONFIG_TARGET_mediatek_filogic=y
CONFIG_TARGET_MULTI_PROFILE=y
CONFIG_TARGET_PER_DEVICE_ROOTFS=y
CONFIG_TARGET_DEVICE_mediatek_filogic_DEVICE_netcore_n30pro=y
CONFIG_TARGET_ROOTFS_SQUASHFS=y

# Reuse compiler results through the GitHub Actions ccache directory.
CONFIG_CCACHE=y

# Remove package build trees after their artifacts are staged to limit CI disk use.
CONFIG_AUTOREMOVE=y

# Allow installing locally built or third-party packages without a repository
# signature. HTTPS transport and source archive hash checks remain enabled.
# CONFIG_SIGNATURE_CHECK is not set

# LuCI (HTTP only; TLS support is deliberately not selected)
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-base=y
CONFIG_PACKAGE_luci-compat=y
CONFIG_PACKAGE_luci-mod-admin-full=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_luci-i18n-base-zh-cn=y

# PassWall2 with Xray as its only explicitly selected proxy core
CONFIG_PACKAGE_luci-app-passwall2=y
CONFIG_PACKAGE_luci-app-passwall2_Nftables_Transparent_Proxy=y
CONFIG_PACKAGE_xray-core=y
CONFIG_PACKAGE_v2ray-geodata=y

# Common LuCI applications
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-app-samba4=y
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-app-wol=y
CONFIG_PACKAGE_luci-app-nlbwmon=y

# Useful supporting utilities
CONFIG_PACKAGE_bash=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_ca-bundle=y
CONFIG_PACKAGE_ca-certificates=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_iptables-nft=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_kmod-usb3=y
CONFIG_PACKAGE_block-mount=y
CONFIG_PACKAGE_kmod-usb-storage=y
CONFIG_PACKAGE_kmod-usb-storage-uas=y
CONFIG_PACKAGE_kmod-fs-ext4=y
CONFIG_PACKAGE_e2fsprogs=y
CONFIG_PACKAGE_zram-swap=y
CONFIG_PACKAGE_nano-full=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_samba4-server=y
CONFIG_PACKAGE_ttyd=y
CONFIG_PACKAGE_uhttpd=y
CONFIG_PACKAGE_uhttpd-mod-ubus=y
